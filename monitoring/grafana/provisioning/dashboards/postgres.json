{
  "title": "PostgreSQL — Invoice DB",
  "uid": "invoice-postgres",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    {
      "id": 1, "type": "gauge", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "title": "Buffer Hit Ratio",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "red"},{"value": 95,"color": "yellow"},{"value": 99,"color": "green"}] } },
      "targets": [{
        "expr": "rate(pg_stat_database_blks_hit{datname=\"invoices\"}[1m]) / (rate(pg_stat_database_blks_hit{datname=\"invoices\"}[1m]) + rate(pg_stat_database_blks_read{datname=\"invoices\"}[1m]) + 0.0001) * 100",
        "legendFormat": "Hit Ratio %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },

    {
      "id": 2, "type": "gauge", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "title": "Active Connections",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "green"},{"value": 50,"color": "yellow"},{"value": 80,"color": "red"}] } },
      "targets": [{
        "expr": "sum(pg_stat_activity_count{datname=\"invoices\",state=\"active\"})",
        "legendFormat": "Active"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 3, "type": "gauge", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "title": "Open Connections",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "green"},{"value": 80,"color": "yellow"},{"value": 95,"color": "red"}] } },
      "targets": [{
        "expr": "sum(pg_stat_activity_count{datname=\"invoices\"})",
        "legendFormat": "Total"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 4, "type": "gauge", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "title": "Forced Checkpoints",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "green"},{"value": 1,"color": "red"}] } },
      "targets": [{
        "expr": "pg_stat_bgwriter_checkpoints_req_total",
        "legendFormat": "Forced Checkpoints"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 5, "type": "gauge", "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "title": "Rollback Rate %",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "green"},{"value": 1,"color": "yellow"},{"value": 5,"color": "red"}] } },
      "targets": [{
        "expr": "rate(pg_stat_database_xact_rollback{datname=\"invoices\"}[1m]) / (rate(pg_stat_database_xact_commit{datname=\"invoices\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=\"invoices\"}[1m]) + 0.0001) * 100",
        "legendFormat": "Rollback %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },

    {
      "id": 20, "type": "stat", "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "title": "buffers_backend (Pressure)",
      "description": "High = buffer too small. Backends forced to flush dirty pages.",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "pg_stat_bgwriter_buffers_backend_total",
        "legendFormat": "buffers_backend"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"value": null,"color": "green"},{"value": 100,"color": "yellow"},{"value": 1000,"color": "red"}] } } }
    },

    {
      "id": 6, "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "title": "Buffer Hit Ratio Over Time",
      "targets": [{
        "expr": "rate(pg_stat_database_blks_hit{datname=\"invoices\"}[1m]) / (rate(pg_stat_database_blks_hit{datname=\"invoices\"}[1m]) + rate(pg_stat_database_blks_read{datname=\"invoices\"}[1m]) + 0.0001) * 100",
        "legendFormat": "Hit Ratio %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 80, "max": 100, "color": { "mode": "fixed", "fixedColor": "green" } } }
    },

    {
      "id": 7, "type": "timeseries", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "title": "Buffer Pressure — buffers_backend (KEY metric)",
      "description": "Rising = buffer too small, backends blocking on every INSERT batch",
      "targets": [{
        "expr": "rate(pg_stat_bgwriter_buffers_backend_total[1m])",
        "legendFormat": "buffers_backend/s (pressure)"
      },{
        "expr": "rate(pg_stat_bgwriter_buffers_clean_total[1m])",
        "legendFormat": "buffers_clean/s (healthy bgwriter)"
      },{
        "expr": "rate(pg_stat_bgwriter_buffers_checkpoint_total[1m])",
        "legendFormat": "buffers_checkpoint/s"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 8, "type": "timeseries", "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "title": "Throughput — Transactions per Second",
      "targets": [{
        "expr": "rate(pg_stat_database_xact_commit{datname=\"invoices\"}[1m])",
        "legendFormat": "Commits/s"
      },{
        "expr": "rate(pg_stat_database_xact_rollback{datname=\"invoices\"}[1m])",
        "legendFormat": "Rollbacks/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 9, "type": "timeseries", "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "title": "Row Operations per Second",
      "targets": [{
        "expr": "rate(pg_stat_database_tup_inserted{datname=\"invoices\"}[1m])",
        "legendFormat": "Inserts/s"
      },{
        "expr": "rate(pg_stat_database_tup_updated{datname=\"invoices\"}[1m])",
        "legendFormat": "Updates/s"
      },{
        "expr": "rate(pg_stat_database_tup_deleted{datname=\"invoices\"}[1m])",
        "legendFormat": "Deletes/s"
      },{
        "expr": "rate(pg_stat_database_tup_fetched{datname=\"invoices\"}[1m])",
        "legendFormat": "Reads/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 10, "type": "timeseries", "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "title": "Connections by State",
      "targets": [{
        "expr": "sum(pg_stat_activity_count{datname=\"invoices\",state=\"active\"})",
        "legendFormat": "Active"
      },{
        "expr": "sum(pg_stat_activity_count{datname=\"invoices\",state=\"idle\"})",
        "legendFormat": "Idle"
      },{
        "expr": "sum(pg_stat_activity_count{datname=\"invoices\",state=\"idle in transaction\"})",
        "legendFormat": "Idle in Txn (warning)"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 11, "type": "timeseries", "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "title": "Disk Reads vs Cache Hits/s",
      "description": "disk_reads rising = buffer too small, queries hitting disk",
      "targets": [{
        "expr": "rate(pg_stat_database_blks_read{datname=\"invoices\"}[1m])",
        "legendFormat": "Disk Reads/s"
      },{
        "expr": "rate(pg_stat_database_blks_hit{datname=\"invoices\"}[1m])",
        "legendFormat": "Cache Hits/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 13, "type": "timeseries", "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "title": "Write Latency (INSERT/UPDATE/DELETE) ms",
      "description": "Average and max latency for write operations only",
      "targets": [{
        "expr": "pg_write_latency_write_avg_ms",
        "legendFormat": "Write Avg ms"
      },{
        "expr": "pg_write_latency_write_max_ms",
        "legendFormat": "Write Max ms"
      },{
        "expr": "pg_read_latency_read_avg_ms",
        "legendFormat": "Read Avg ms"
      },{
        "expr": "pg_read_latency_read_max_ms",
        "legendFormat": "Read Max ms"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "id": 14, "type": "timeseries", "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "title": "Throughput — Read vs Write calls/s",
      "targets": [{
        "expr": "rate(pg_write_latency_write_calls[1m])",
        "legendFormat": "Writes/s (INSERT/UPDATE/DELETE)"
      },{
        "expr": "rate(pg_read_latency_read_calls[1m])",
        "legendFormat": "Reads/s (SELECT)"
      },{
        "expr": "rate(pg_query_throughput_total_rows[1m])",
        "legendFormat": "Rows/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 15, "type": "timeseries", "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "title": "Overall Query Latency (All operations)",
      "targets": [{
        "expr": "pg_query_throughput_overall_avg_ms",
        "legendFormat": "Overall Avg ms"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "id": 16, "type": "table", "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "title": "Top Slow Queries",
      "targets": [{
        "expr": "topk(10, pg_slow_queries_avg_ms)",
        "legendFormat": "{{operation_type}} | {{query}}",
        "instant": true
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "id": 12, "type": "timeseries", "gridPos": { "x": 0, "y": 44, "w": 24, "h": 8 },
      "title": "Table Row Counts",
      "targets": [{
        "expr": "pg_stat_user_tables_n_live_tup{relname=\"invoices_header\"}",
        "legendFormat": "invoices_header (live rows)"
      },{
        "expr": "pg_stat_user_tables_n_live_tup{relname=\"invoices_line_items\"}",
        "legendFormat": "invoices_line_items (live rows)"
      },{
        "expr": "pg_stat_user_tables_n_dead_tup{relname=\"invoices_line_items\"}",
        "legendFormat": "line_items dead tuples (bloat)"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }

  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
